#!/usr/bin/env python3
"""셀프 호스트 Outline 위키 API 래퍼 CLI.

Python 3 표준 라이브러리만 사용하는 단일 파일 도구.
플러그인 bin/ 은 Bash PATH 에 자동 추가되므로 `outline <subcommand>` 로 호출한다.
베이스 URL 은 내장하지 않고 `OUTLINE_URL` env 로만 공급받는다.

구현 명세: .claude/skills/outline-cli/SKILL.md
"""

import argparse
import html
import http.client
import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.request

TIMEOUT = 30

REGISTER_HINT = (
    "토큰 등록 방법:\n"
    "  1) macOS 키체인 (권장):\n"
    '     security add-generic-password -s outline-token -a "$USER" -w "<API 토큰>"\n'
    "  2) 환경변수:\n"
    '     export OUTLINE_API_TOKEN="<API 토큰>"\n'
    "  API 토큰은 Outline 위키 설정 → API Tokens 에서 발급합니다."
)

URL_HINT = (
    "베이스 URL 설정 방법:\n"
    "  1) 셸 프로필 (예: ~/.zshrc, ~/.bashrc):\n"
    '     export OUTLINE_URL="https://<위키 도메인>"\n'
    "  2) Claude Code 사용자 설정 (~/.claude/settings.json) — Claude Code 세션에만 적용됨:\n"
    '     "env": { "OUTLINE_URL": "https://<위키 도메인>" }\n'
    "  사용 중인 Outline 인스턴스의 주소로 지정하세요."
)


# --------------------------------------------------------------------------
# 인증 · URL 해석
# --------------------------------------------------------------------------
def token_from_keychain():
    """macOS 키체인에서 outline-token 을 읽는다.

    토큰은 stdout 으로만 받는다(프로세스 인자에 토큰이 들어가지 않음).
    security 가 없는 플랫폼(비 macOS)이면 조용히 None 을 반환한다.
    """
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "outline-token", "-w"],
            capture_output=True,
            text=True,
            timeout=10,
        )
    except (FileNotFoundError, OSError, subprocess.SubprocessError):
        return None
    if result.returncode != 0:
        return None
    token = result.stdout.strip()
    return token or None


def resolve_token():
    """① OUTLINE_API_TOKEN env (빈 문자열은 미설정) → ② 키체인."""
    env_token = os.environ.get("OUTLINE_API_TOKEN")
    if env_token:  # 빈 문자열/미설정은 falsy → 건너뜀
        return env_token
    return token_from_keychain()


def resolve_base_url():
    """OUTLINE_URL env 필수 (기본값 없음, 빈 문자열은 미설정). 미설정이면 None."""
    url = os.environ.get("OUTLINE_URL")
    if url:  # 빈 문자열/미설정은 falsy → 미설정 취급
        return url
    return None


def print_token_missing():
    sys.stderr.write("오류: Outline API 토큰을 찾을 수 없습니다.\n")
    sys.stderr.write(REGISTER_HINT + "\n")
    sys.exit(2)


def print_url_missing():
    sys.stderr.write("오류: 베이스 URL(OUTLINE_URL)이 설정되지 않았습니다.\n")
    sys.stderr.write(URL_HINT + "\n")
    sys.exit(2)


# --------------------------------------------------------------------------
# API 호출
# --------------------------------------------------------------------------
def _http_error(err):
    """HTTPError 를 stderr 안내 + message 병기 후 exit 1."""
    code = err.code
    try:
        body = err.read().decode("utf-8")
        message = json.loads(body).get("message", "")
    except Exception:
        message = ""
    if code == 401:
        guide = "토큰이 유효하지 않거나 만료되었습니다.\n" + REGISTER_HINT
    elif code == 403:
        guide = "권한 부족 — 문서/컬렉션 권한 또는 API 키 스코프를 확인하세요."
    elif code == 404:
        guide = "문서/컬렉션 ID 를 확인하세요."
    elif code == 429:
        guide = "rate limit — 잠시 후 재시도하세요."
    else:
        guide = "HTTP %d" % code
    sys.stderr.write("오류: " + guide + "\n")
    if message:
        sys.stderr.write("API message: " + message + "\n")
    sys.exit(1)


def call(endpoint, payload, token, base_url):
    """POST {base}/api/{endpoint} — JSON body, Bearer 인증, 30초 timeout."""
    url = base_url.rstrip("/") + "/api/" + endpoint
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST")
    req.add_header("Authorization", "Bearer " + token)
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=TIMEOUT) as resp:
            raw = resp.read().decode("utf-8")
    except urllib.error.HTTPError as err:
        _http_error(err)  # exit 1
    except (
        urllib.error.URLError,
        http.client.HTTPException,
        TimeoutError,
        OSError,
    ) as err:
        # URLError/타임아웃 + 응답 수신 중 연결 리셋(ConnectionResetError 등
        # OSError 계열)·http.client 예외까지 "기타/네트워크"로 처리.
        reason = getattr(err, "reason", None) or err
        sys.stderr.write("오류: 네트워크 오류 — %s\n" % reason)
        sys.exit(1)
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        sys.stderr.write("오류: API 응답을 JSON 으로 파싱할 수 없습니다.\n")
        sys.exit(1)


# --------------------------------------------------------------------------
# 유틸
# --------------------------------------------------------------------------
def normalize_doc_id(value):
    """전체 URL 도 허용 — 마지막 path segment 를 추출한다."""
    v = value.strip()
    if "/" in v:
        v = v.split("#", 1)[0].split("?", 1)[0]
        segments = [s for s in v.split("/") if s]
        if segments:
            return segments[-1]
    return v


_UUID_RE = re.compile(
    r"^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}"
    r"-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
)


def is_uuid(value):
    """UUID(8-4-4-4-12 hex) 형식인지 — 아니면 urlId·URL 유래로 본다."""
    return bool(_UUID_RE.match(value))


def abs_url(base_url, rel):
    """API 응답의 상대 경로에 base URL 을 붙여 절대 URL 을 만든다."""
    if not rel:
        return ""
    if rel.startswith("http://") or rel.startswith("https://"):
        return rel
    # 상대 경로가 "/"로 시작하지 않아도 malformed URL 이 되지 않도록 보정.
    # (현재 Outline 응답은 항상 "/doc/..." 형태라 동작 변화 없음.)
    if not rel.startswith("/"):
        rel = "/" + rel
    return base_url.rstrip("/") + rel


def clean_snippet(text, limit=200):
    """HTML 태그 제거 + 엔티티 복원 + 공백 정규화 + ~200자 절단."""
    if not text:
        return ""
    text = re.sub(r"<[^>]+>", "", text)
    text = html.unescape(text)
    text = " ".join(text.split())
    if len(text) > limit:
        text = text[:limit].rstrip() + "…"
    return text


def read_body_file(path, sub):
    try:
        with open(path, "r", encoding="utf-8") as fh:
            return fh.read()
    except OSError as err:
        sub.error("본문 파일을 읽을 수 없습니다: %s (%s)" % (path, err.strerror or err))


# ---- 코드 펜스 추적 (문자 종류·길이 매칭) --------------------------------
_OPEN_FENCE_RE = re.compile(r"^ {0,3}(`{3,}|~{3,})")


def _opening_fence(line):
    """펜스 여는 줄이면 (문자, 길이)를 반환, 아니면 None."""
    m = _OPEN_FENCE_RE.match(line)
    if not m:
        return None
    run = m.group(1)
    return run[0], len(run)


def _closing_fence(line, char, length):
    """열린 펜스(char, length)를 닫는 줄인지 — 같은 문자로만·길이 이상.

    정보 문자열이 붙은 줄은 닫는 펜스가 아니다. ``` 블록 안의 ~~~ 처럼
    문자 종류가 다른 줄도 닫지 못한다(무조건 토글 금지).
    """
    s = line.strip()
    if not s or s[0] != char:
        return False
    if s != char * len(s):
        return False
    return len(s) >= length


def _classify_fences(lines):
    """각 줄을 펜스 상태로 분류: 'text'|'fence_open'|'fence_body'|'fence_close'."""
    tags = []
    fence = None  # 열려 있으면 (char, length)
    for line in lines:
        if fence is None:
            opened = _opening_fence(line)
            if opened:
                fence = opened
                tags.append("fence_open")
            else:
                tags.append("text")
        else:
            if _closing_fence(line, fence[0], fence[1]):
                fence = None
                tags.append("fence_close")
            else:
                tags.append("fence_body")
    return tags


# ---- 표 병합 복구 --------------------------------------------------------
_SEP_CELL_RE = re.compile(r"^:?-+:?$")


def _is_separator_row(line):
    """GFM 표 구분자 행(`|---|` 계열, 셀별 `:` 정렬 마커 허용)인지."""
    s = line.strip()
    if not s.startswith("|"):
        return False
    inner = s.strip("|").strip()
    if not inner:
        return False
    for cell in inner.split("|"):
        if not _SEP_CELL_RE.match(cell.strip()):
            return False
    return True


def normalize_tables(text):
    """여러 물리 줄로 갈라진 표 행을 한 줄로 병합해 유효한 GFM 으로 만든다.

    Outline 은 셀 안에 블록 요소(목록·여러 문단)가 있는 표를 마크다운으로
    내보낼 때 행 하나를 여러 줄로 직렬화한다. 그대로 다시 업로드하면 GFM
    파서(한 행 = 한 줄)가 표를 깨뜨리므로, 표 블록 안에서 `|` 로 시작하지
    않는 연속 줄을 직전 행에 병합한다.
    - 직전 행이 `|` 로 끝나면: 셀 여는 파이프 직후의 줄바꿈 → 공백으로 연결
    - 아니면: 셀 안 줄바꿈 → `<br>` 로 연결

    오병합 방지 가드 3종:
    1. 표 진입은 `|` 시작 줄의 다음 물리 줄이 구분자 행일 때만 (lookahead).
       구분자 행 없는 파이프 줄(들여쓰기 코드·`|x|` 문단)은 병합하지 않는다.
    2. 표 안이라도 헤딩(`#`)·인용(`>`)·펜스 시작 줄은 병합하지 않고 표 종료.
    3. 코드 펜스(``` / ~~~)는 문자 종류·길이 매칭으로 추적하며 건드리지 않음.
    """
    lines = text.split("\n")
    tags = _classify_fences(lines)
    n = len(lines)
    out = []
    in_table = False
    for i, line in enumerate(lines):
        if tags[i] != "text":
            # 펜스 여는/내부/닫는 줄 — 병합 대상 아님, 표 종료
            in_table = False
            out.append(line)
            continue
        stripped = line.strip()
        if not in_table:
            if (
                stripped.startswith("|")
                and i + 1 < n
                and tags[i + 1] == "text"
                and _is_separator_row(lines[i + 1])
            ):
                in_table = True
            out.append(line)
            continue
        # 표 블록 안
        if not stripped:
            in_table = False
            out.append(line)
            continue
        if stripped.startswith("|"):
            out.append(line)  # 새 표 행(구분자 행 포함)
            continue
        if stripped.startswith("#") or stripped.startswith(">"):
            in_table = False  # 새 블록 시작 — 병합 제외, 표 종료
            out.append(line)
            continue
        # 셀 내부 블록의 이어지는 줄 — 직전 행에 병합
        prev = out[-1].rstrip()
        joiner = " " if prev.endswith("|") else "<br>"
        out[-1] = prev + joiner + stripped
    return "\n".join(out)


# ---- 왕복 검증용 정규화 --------------------------------------------------
_ASCII_PUNCT = set("!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~")


def _unescape_ascii_punct(t):
    r"""CommonMark 규칙: ASCII 구두점 앞 백슬래시만 해제.

    비구두점·개행 앞 백슬래시는 유지한다 (`C:\new` 오탐 방지).
    """
    out = []
    i = 0
    length = len(t)
    while i < length:
        if t[i] == "\\" and i + 1 < length and t[i + 1] in _ASCII_PUNCT:
            out.append(t[i + 1])
            i += 2
        else:
            out.append(t[i])
            i += 1
    return "".join(out)


def _canonical_prose(text):
    """산문 구간의 느슨한 정규화 — Outline 재직렬화의 무해한 변형을 흡수."""
    t = _unescape_ascii_punct(text)
    # 하드 브레이크·행말 변형 → 개행, &nbsp; → 공백
    t = re.sub(r"\\\n", "\n", t)
    t = re.sub(r" {2,}\n", "\n", t)
    t = re.sub(r"<br\s*/?>", "\n", t, flags=re.IGNORECASE)
    t = re.sub(r"&nbsp;", " ", t, flags=re.IGNORECASE)
    # 강조 구분자 동치화
    t = t.replace("_", "*")
    # 목록 마커 정규화 (들여쓰기 깊이 무제한, 불릿·순서 동일 규칙)
    t = re.sub(r"(?m)^[ \t]*[-*+][ \t]+", "•", t)
    t = re.sub(r"(?m)^[ \t]*\d+[.)][ \t]+", "#.", t)
    # 제목 동치화: ATX 마커 제거 + setext 밑줄·수평선 제거
    t = re.sub(r"(?m)^[ \t]*#{1,6}[ \t]+", "", t)
    t = re.sub(r"(?m)^[ \t]*[-=*_]{3,}[ \t]*$", "", t)
    # 남은 공백 전부 제거
    t = re.sub(r"\s+", "", t)
    return t


def _render_canonical_part(kind, buf):
    if kind == "fence":
        # 펜스 내부는 원문 유지(들여쓰기 변경이 불일치로 잡혀야 함), 행 우측 공백만 무시
        return "\n".join(ln.rstrip() for ln in buf)
    return _canonical_prose("\n".join(buf))


def canonical_text(text):
    """왕복 검증용 정규형 — 펜스 내부는 엄격(행 우측 공백만 무시), 산문만 느슨.

    코드 펜스 구간/산문 구간으로 분할해 산문만 느슨 정규화하고, 펜스 내부는
    각 행 rstrip 후 원문을 유지한다. 구간은 NUL 로 이어 붙여 경계 침식을 막는다.
    """
    text = normalize_tables(text)
    lines = text.split("\n")
    tags = _classify_fences(lines)
    parts = []
    buf = []
    buf_kind = None  # "prose" | "fence"
    for line, tag in zip(lines, tags):
        kind = "prose" if tag == "text" else "fence"
        if buf_kind is None or kind == buf_kind:
            buf.append(line)
            buf_kind = kind
        else:
            parts.append(_render_canonical_part(buf_kind, buf))
            buf = [line]
            buf_kind = kind
    if buf:
        parts.append(_render_canonical_part(buf_kind, buf))
    return "\x00".join(parts)


# --------------------------------------------------------------------------
# 서브커맨드 핸들러
# --------------------------------------------------------------------------
def cmd_doctor(args, token, base_url, subs):
    data = call("auth.info", {}, token, base_url)
    info = data.get("data", {}) or {}
    user = info.get("user", {}) or {}
    team = info.get("team", {}) or {}
    print("OK: 인증 성공")
    print("사용자: %s <%s>" % (user.get("name", "?"), user.get("email", "?")))
    print("팀: %s (%s)" % (team.get("name", "?"), team.get("url", "")))


def cmd_search(args, token, base_url, subs):
    payload = {"query": args.query, "limit": args.limit}
    if args.collection:
        payload["collectionId"] = args.collection
    data = call("documents.search", payload, token, base_url)
    results = data.get("data", []) or []
    if not results:
        print("(검색 결과 없음)")
        return
    for item in results:
        doc = item.get("document", {}) or {}
        snippet = clean_snippet(item.get("context", ""))
        print("- %s" % doc.get("title", "(제목 없음)"))
        print("  id: %s" % doc.get("id", ""))
        print("  url: %s" % abs_url(base_url, doc.get("url", "")))
        if snippet:
            print("  snippet: %s" % snippet)


def cmd_read(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    data = call("documents.info", {"id": doc_id}, token, base_url)
    d = data.get("data", {}) or {}
    print(
        "제목: %s | id: %s | collectionId: %s | updatedAt: %s | url: %s"
        % (
            d.get("title", ""),
            d.get("id", ""),
            d.get("collectionId", ""),
            d.get("updatedAt", ""),
            abs_url(base_url, d.get("url", "")),
        )
    )
    print()
    print(normalize_tables(d.get("text", "")))


def cmd_list(args, token, base_url, subs):
    payload = {"limit": args.limit, "sort": "updatedAt", "direction": "DESC"}
    if args.collection:
        payload["collectionId"] = args.collection
    data = call("documents.list", payload, token, base_url)
    docs = data.get("data", []) or []
    if not docs:
        print("(문서 없음)")
        return
    for d in docs:
        print("%s  %s" % (d.get("id", ""), d.get("title", "(제목 없음)")))


def cmd_tree(args, token, base_url, subs):
    data = call("collections.documents", {"id": args.collectionId}, token, base_url)
    nodes = data.get("data", []) or []
    if not nodes:
        print("(빈 컬렉션)")
        return

    def walk(items, depth):
        for n in items:
            print(
                "%s- %s  [%s]"
                % ("  " * depth, n.get("title", "(제목 없음)"), n.get("id", ""))
            )
            children = n.get("children", []) or []
            if children:
                walk(children, depth + 1)

    walk(nodes, 0)


def cmd_collections(args, token, base_url, subs):
    data = call("collections.list", {"limit": 100}, token, base_url)
    colls = data.get("data", []) or []
    if not colls:
        print("(컬렉션 없음)")
        return
    for c in colls:
        print("%s  %s" % (c.get("id", ""), c.get("name", "(이름 없음)")))


def cmd_create(args, token, base_url, subs):
    # update 와 대칭 — 표 병합 복구 적용 (신규 저작이므로 왕복 검증은 없음)
    body = normalize_tables(read_body_file(args.body_file, subs["create"]))
    payload = {"title": args.title, "text": body, "publish": bool(args.publish)}
    if args.collection:
        payload["collectionId"] = args.collection
    if args.parent:
        payload["parentDocumentId"] = normalize_doc_id(args.parent)
    data = call("documents.create", payload, token, base_url)
    d = data.get("data", {}) or {}
    status = "발행됨" if args.publish else "draft"
    print("생성됨 (%s): %s" % (status, d.get("title", "")))
    print("id: %s" % d.get("id", ""))
    print("url: %s" % abs_url(base_url, d.get("url", "")))


def cmd_update(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    payload = {"id": doc_id}
    body = None
    if args.title:
        payload["title"] = args.title
    if args.body_file:
        raw = read_body_file(args.body_file, subs["update"])
        if args.append:
            # append 조각은 정규화하지 않는다 (신규 저작 조각 + 검증 불가)
            payload["text"] = raw
        else:
            body = normalize_tables(raw)  # 전체 교체 시에만 표 병합 복구
            payload["text"] = body
    if args.append:
        payload["append"] = True
    data = call("documents.update", payload, token, base_url)
    d = data.get("data", {}) or {}
    print("수정됨: %s" % d.get("title", ""))
    print("id: %s" % d.get("id", doc_id))
    print("url: %s" % abs_url(base_url, d.get("url", "")))

    # 전체 본문 교체 시에만 왕복 검증 (--append·--title 단독은 검증 제외).
    # documents.update 응답의 data.text(서버 재직렬화 저장본)와 직접 비교한다 —
    # documents.info 재호출은 불필요한 왕복·동시편집 레이스 오탐을 만든다.
    if body is None or args.append:
        return
    stored = d.get("text", "")
    if canonical_text(stored) != canonical_text(body):
        # 안내에 넣는 docId 는 응답의 UUID (urlId 는 revisions.list 가 거부).
        uid = d.get("id", doc_id)
        sys.stderr.write(
            "경고: 저장은 완료됐지만, 저장된 본문이 보낸 본문과 다릅니다"
            " (왕복 변환 손실 가능).\n"
            "  현재 상태 확인: outline read %s\n"
            "  이전 버전 목록: outline revisions %s\n"
            "  되돌리기:       outline revert %s <revisionId>\n" % (uid, uid, uid)
        )
        sys.exit(3)


def cmd_move(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    payload = {"id": doc_id}
    if args.collection:
        payload["collectionId"] = args.collection
    if args.parent:
        payload["parentDocumentId"] = normalize_doc_id(args.parent)
    call("documents.move", payload, token, base_url)
    print("이동됨: %s" % doc_id)


def cmd_archive(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    data = call("documents.archive", {"id": doc_id}, token, base_url)
    d = data.get("data", {}) or {}
    print("아카이브됨: %s  [%s]" % (d.get("title", doc_id), d.get("id", doc_id)))


def cmd_delete(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    call("documents.delete", {"id": doc_id}, token, base_url)
    print("삭제됨(휴지통 이동): %s" % doc_id)
    print("복구하려면: outline restore %s" % doc_id)


def cmd_restore(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    data = call("documents.restore", {"id": doc_id}, token, base_url)
    d = data.get("data", {}) or {}
    print("복원됨: %s  [%s]" % (d.get("title", doc_id), d.get("id", doc_id)))


def cmd_revisions(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    # revisions.list 는 documents.* 와 달리 urlId 를 받지 않는다.
    # UUID 가 아니면(urlId·URL 유래) documents.info 로 UUID 를 먼저 해석한다.
    if not is_uuid(doc_id):
        info = call("documents.info", {"id": doc_id}, token, base_url)
        resolved = (info.get("data", {}) or {}).get("id", "")
        if resolved:
            doc_id = resolved
    data = call(
        "revisions.list", {"documentId": doc_id, "limit": args.limit}, token, base_url
    )
    revs = data.get("data", []) or []
    if not revs:
        print("(리비전 없음)")
        return
    for r in revs:
        by = (r.get("createdBy") or {}).get("name", "?")
        print(
            "%s  %s  %s  %s"
            % (r.get("id", ""), r.get("createdAt", ""), by, r.get("title", ""))
        )


def cmd_revert(args, token, base_url, subs):
    doc_id = normalize_doc_id(args.doc)
    data = call(
        "documents.restore", {"id": doc_id, "revisionId": args.revision}, token, base_url
    )
    d = data.get("data", {}) or {}
    print("되돌림: %s  [%s]" % (d.get("title", doc_id), d.get("id", doc_id)))
    print("url: %s" % abs_url(base_url, d.get("url", "")))


HANDLERS = {
    "doctor": cmd_doctor,
    "search": cmd_search,
    "read": cmd_read,
    "list": cmd_list,
    "tree": cmd_tree,
    "collections": cmd_collections,
    "create": cmd_create,
    "update": cmd_update,
    "move": cmd_move,
    "archive": cmd_archive,
    "delete": cmd_delete,
    "restore": cmd_restore,
    "revisions": cmd_revisions,
    "revert": cmd_revert,
}


# --------------------------------------------------------------------------
# 파서
# --------------------------------------------------------------------------
def build_parser():
    parser = argparse.ArgumentParser(
        prog="outline",
        description="셀프 호스트 Outline 위키 API 래퍼 CLI (베이스 URL 은 OUTLINE_URL env)",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>", required=True)
    subs = {}

    subs["doctor"] = sub.add_parser("doctor", help="토큰·계정 확인 (셋업 검증용)")

    p = sub.add_parser("search", help="문서 검색 (documents.search)")
    p.add_argument("query", help="검색어")
    p.add_argument("--collection", help="컬렉션 ID 로 범위 제한")
    p.add_argument("--limit", type=int, default=10, help="최대 결과 수 (기본 10)")
    subs["search"] = p

    p = sub.add_parser("read", help="문서 조회 — 메타 헤더 + 마크다운 본문")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    subs["read"] = p

    p = sub.add_parser("list", help="문서 목록 (updatedAt DESC)")
    p.add_argument("--collection", help="컬렉션 ID 로 범위 제한")
    p.add_argument("--limit", type=int, default=25, help="최대 결과 수 (기본 25)")
    subs["list"] = p

    p = sub.add_parser("tree", help="컬렉션 문서 트리 (들여쓰기 + id)")
    p.add_argument("collectionId", help="컬렉션 ID")
    subs["tree"] = p

    subs["collections"] = sub.add_parser("collections", help="컬렉션 목록 (id, 이름)")

    p = sub.add_parser("create", help="문서 생성 (기본 draft)")
    p.add_argument("--title", required=True, help="문서 제목")
    p.add_argument("--collection", help="컬렉션 ID (--publish 시 필수)")
    p.add_argument("--parent", metavar="docId|URL", help="상위 문서 ID")
    p.add_argument("--body-file", required=True, metavar="FILE", help="본문 파일 경로")
    p.add_argument("--publish", action="store_true", help="즉시 발행 (--collection 필수)")
    subs["create"] = p

    p = sub.add_parser("update", help="문서 수정 (전체 본문 교체, 저장 후 왕복 검증)")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    p.add_argument("--body-file", metavar="FILE", help="새 본문 파일 경로")
    p.add_argument("--title", help="새 제목")
    p.add_argument("--append", action="store_true", help="본문을 추가 (--body-file 필수)")
    subs["update"] = p

    p = sub.add_parser("move", help="문서 이동")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    p.add_argument("--collection", help="대상 컬렉션 ID")
    p.add_argument("--parent", metavar="docId|URL", help="대상 상위 문서 ID")
    subs["move"] = p

    p = sub.add_parser("archive", help="문서 아카이브")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    subs["archive"] = p

    p = sub.add_parser("delete", help="문서 삭제 (휴지통 이동만)")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    subs["delete"] = p

    p = sub.add_parser("restore", help="문서 복원 (휴지통에서)")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    subs["restore"] = p

    p = sub.add_parser("revisions", help="문서 리비전 목록 (최신순)")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    p.add_argument("--limit", type=int, default=10, help="최대 결과 수 (기본 10)")
    subs["revisions"] = p

    p = sub.add_parser("revert", help="문서를 특정 리비전으로 되돌리기")
    p.add_argument("doc", metavar="docId|URL", help="문서 ID 또는 전체 URL")
    p.add_argument("revision", metavar="revisionId", help="되돌릴 리비전 ID")
    subs["revert"] = p

    return parser, subs


def validate(args, subs):
    """usage 레벨 검증 — API 호출 전에 exit 2 로 거부."""
    if args.command == "create":
        if args.publish and not args.collection:
            subs["create"].error(
                "--publish 지정 시 --collection 이 필요합니다 (발행 문서는 컬렉션 필수)"
            )
    elif args.command == "update":
        if args.append and not args.body_file:
            subs["update"].error("--append 는 --body-file 이 필요합니다")
        if not args.body_file and not args.title:
            subs["update"].error(
                "수정할 내용이 없습니다 — --body-file 또는 --title 중 하나 이상이 필요합니다"
            )
    elif args.command == "move":
        if not args.collection and not args.parent:
            subs["move"].error(
                "이동 대상이 없습니다 — --collection 또는 --parent 중 하나 이상이 필요합니다"
            )


def main():
    parser, subs = build_parser()
    args = parser.parse_args()

    # 1) usage 검증 (토큰·URL 해석·API 호출 전)
    validate(args, subs)

    # 2) 토큰 해석 (확인 순서 고정: ① 토큰 → ② URL)
    token = resolve_token()
    if not token:
        print_token_missing()  # exit 2

    # 3) base URL 해석 — OUTLINE_URL 필수, 미설정이면 exit 2
    base_url = resolve_base_url()
    if not base_url:
        print_url_missing()  # exit 2

    # 4) 디스패치
    HANDLERS[args.command](args, token, base_url, subs)


if __name__ == "__main__":
    main()
